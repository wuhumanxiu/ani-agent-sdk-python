{
  "name": "ani-agent-protocol",
  "version": "2026.5.14",
  "serverUrl": "https://agent-native.im",
  "apiBasePath": "/api/v1",
  "webSocketPath": "/api/v1/ws",
  "source": {
    "repository": "https://github.com/wuhumanxiu/agent-native-im",
    "openapi": "docs/protocol/openapi.yaml",
    "webSocketSchema": "docs/protocol/ws-events.schema.json"
  },
  "requiredRestPaths": [
    "/api/v1/me",
    "/api/v1/ws",
    "/api/v1/messages/send",
    "/api/v1/conversations",
    "/api/v1/conversations/{id}/messages",
    "/api/v1/conversations/by-public-id/{publicId}",
    "/api/v1/files/upload"
  ],
  "requiredSendFields": [
    "conversation_id",
    "content_type",
    "layers",
    "attachments",
    "mentions",
    "mention_public_ids",
    "mention_refs",
    "assigned_public_ids",
    "conversation_public_id",
    "reply_to"
  ],
  "requiredPublicIdFields": [
    "public_id",
    "conversation_public_id",
    "sender_public_id",
    "source_public_id",
    "target_public_id",
    "participant_public_ids",
    "entity_public_id",
    "assigned_public_ids",
    "public_ids",
    "presence_by_public_id"
  ],
  "requiredWebSocketEvents": [
    "message.new",
    "message.send",
    "message.progress",
    "stream.start",
    "stream.delta",
    "stream.end",
    "stream.cancel",
    "task.cancel",
    "task.cancelled",
    "friend.request.created",
    "friend.request.updated",
    "notification.new",
    "notification.read",
    "notification.read_all",
    "pong",
    "error"
  ]
}
